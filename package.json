{
  "name": "bombastic",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "npm run format && npm run check && vite build",
    "build:preview": "vite build --mode preview",
    "build:test": "npm run check && vite build",
    "build:vercel": "npm run check && vite build --mode production",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "dev:memory": "NODE_OPTIONS='--max-old-space-size=4096' vite dev",
    "dev:no-processing": "DISABLE_IMAGE_PROCESSING=true vite dev",
    "dev:test": "NODE_ENV=test vite dev --mode test",
    "format": "node --max-old-space-size=4096 ./node_modules/.bin/prettier --write --log-level error .",
    "format:src": "node --max-old-space-size=4096 ./node_modules/.bin/prettier --write --log-level error src/",
    "format:check": "node --max-old-space-size=4096 ./node_modules/.bin/prettier --check --log-level error .",
    "generate-types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "lint": "node --max-old-space-size=4096 ./node_modules/.bin/prettier --check . && node --max-old-space-size=8192 ./node_modules/.bin/eslint .",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "supabase:seed": "supabase db dump -f supabase/seed.sql --data-only -x public.notifications -x storage.buckets -x storage.objects -x storage.prefixes",
    "supabase:seed-images": "tsx supabase/scripts/seed-content-images.ts",
    "supabase:upload-images": "tsx supabase/scripts/upload-content-images.ts",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:db:reset": "supabase db reset",
    "test:db:setup": "node scripts/setup-test-db.js",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium ",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:desktop": "playwright test --project='chromium' --project='firefox' --project='webkit'",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:report": "playwright show-report",
    "test:e2e:reset": "RESET_DB=true playwright test",
    "test:e2e:reset-each": "RESET_DB=true RESET_DB_EACH_TEST=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "vitest run src/routes/",
    "test:e2e:single": "playwright test --grep",
    "test:e2e:headed:single": "playwright test --headed --grep",
    "test:setup": "supabase start && npm run generate-types",
    "test:sql": "supabase test db",
    "test:teardown": "supabase stop",
    "test:unit": "vitest run src/lib/",
    "test:watch": "vitest --ui",
    "twitch:webhook:setup": "tsx scripts/setup-twitch-webhooks.ts setup",
    "twitch:webhook:list": "tsx scripts/setup-twitch-webhooks.ts list",
    "twitch:webhook:cleanup": "tsx scripts/setup-twitch-webhooks.ts cleanup",
    "vercel-build": "npm run build:vercel"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.32.0",
    "@internationalized/date": "^3.8.2",
    "@lucide/svelte": "^0.515.0",
    "@playwright/test": "^1.55.0",
    "@sveltejs/adapter-auto": "^6.0.1",
    "@sveltejs/adapter-netlify": "^5.1.0",
    "@sveltejs/adapter-vercel": "^5.8.1",
    "@sveltejs/enhanced-img": "^0.7.0",
    "@sveltejs/kit": "^2.27.2",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/table-core": "^8.21.3",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@trigger.dev/build": "4.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/pg": "^8.15.5",
    "@types/sharp": "^0.32.0",
    "@types/youtube": "^0.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "bits-ui": "^2.9.2",
    "clsx": "^2.1.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.11.0",
    "formsnap": "^2.0.1",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "jsdom-global": "^3.0.2",
    "layerchart": "^2.0.0-next.10",
    "mdsvex": "^0.12.3",
    "mode-watcher": "^1.1.0",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "prettier-plugin-embed": "^0.5.0",
    "prettier-plugin-sql": "^0.19.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "remark-gfm": "^4.0.1",
    "remark-slug": "^7.0.1",
    "runed": "^0.31.1",
    "supabase": "^2.76.17",
    "supabase-cli": "^0.0.21",
    "svelte": "^5.38.0",
    "svelte-check": "^4.3.1",
    "svelte-dnd-action": "^0.9.64",
    "svelte-easy-crop": "^4.0.1",
    "svelte-sonner": "^1.0.5",
    "svelte-toolbelt": "^0.9.3",
    "sveltekit-embed": "^0.0.22",
    "sveltekit-flash-message": "^2.4.6",
    "sveltekit-sse": "^0.14.3",
    "sveltekit-superforms": "^2.27.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwind-variants": "^2.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^7.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.6",
    "@googleapis/youtube": "^28.0.0",
    "@neodrag/svelte": "^2.3.3",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@trigger.dev/sdk": "4.0.4",
    "@twurple/api": "^7.4.0",
    "@twurple/auth": "^7.4.0",
    "@twurple/eventsub-http": "^7.4.0",
    "@types/marked": "^5.0.2",
    "@vercel/speed-insights": "^1.2.0",
    "amazon-cognito-identity-js": "^6.3.15",
    "bad-words": "^4.0.0",
    "crypto-js": "^4.2.0",
    "debounce": "^2.2.0",
    "embla-carousel-svelte": "^8.6.0",
    "inngest": "^3.40.1",
    "jose": "^6.0.12",
    "marked": "^16.2.0",
    "paneforge": "^1.0.2",
    "posthog-js": "^1.260.2",
    "posthog-node": "^5.7.0",
    "sharp": "^0.34.3",
    "svelte-radix": "^2.0.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "zod": "^3.25.76"
  }
}
