{
  "name": "cdk",
  "version": "0.1.0",
  "bin": {
    "cdk": "bin/cdk.js"
  },
  "scripts": {
    "build": "tsc",
    "cdk": "cdk",
    "deploy": "npm run build && cdk deploy --all",
    "deploy:production": "npm run build && cdk deploy BombifyStack-Production --all",
    "deploy:staging": "npm run build && cdk deploy BombifyStack-Staging --all",
    "backup": "tsx scripts/trigger-backup.ts",
    "backup:dry-run": "tsx scripts/trigger-backup.ts -- --dry-run",
    "backup:validate": "tsx scripts/validate-backup.ts",
    "backup:staging": "tsx scripts/trigger-backup.ts -- --staging",
    "backup:staging:dry-run": "tsx scripts/trigger-backup.ts -- --staging --dry-run",
    "restore": "tsx scripts/trigger-restore.ts",
    "restore:dry-run": "tsx scripts/trigger-restore.ts -- --dry-run",
    "restore:validate": "tsx scripts/trigger-restore.ts -- --validate-only",
    "restore:staging": "tsx scripts/trigger-restore.ts -- --staging",
    "restore:staging:dry-run": "tsx scripts/trigger-restore.ts -- --staging --dry-run",
    "disaster-recovery": "tsx scripts/disaster-recovery.ts",
    "disaster-recovery:staging": "tsx scripts/disaster-recovery.ts -- --staging",
    "repopulate": "tsx scripts/trigger-repopulate-combined.ts",
    "repopulate:production": "tsx scripts/trigger-repopulate-combined.ts -- --production",
    "repopulate:staging": "tsx scripts/trigger-repopulate-combined.ts -- --staging",
    "repopulate:source": "tsx scripts/trigger-repopulate-combined.ts",
    "repopulate:source:staging": "tsx scripts/trigger-repopulate-combined.ts -- --staging",
    "repopulate:videos": "tsx scripts/trigger-repopulate-combined.ts -- --videos-only",
    "repopulate:videos:staging": "tsx scripts/trigger-repopulate-combined.ts -- --staging --videos-only",
    "repopulate:playlists": "tsx scripts/trigger-repopulate-combined.ts -- --playlists-only",
    "repopulate:playlists:staging": "tsx scripts/trigger-repopulate-combined.ts -- --staging --playlists-only",
    "build:repopulate": "npm run build && npm run repopulate",
    "build:repopulate:staging": "npm run build && npm run repopulate:staging",
    "test": "jest",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.758.0",
    "@aws-sdk/client-sfn": "^3.840.0",
    "@types/aws-lambda": "^8.10.147",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.16.0",
    "@types/pg": "^8.11.6",
    "aws-cdk": "2.173.1",
    "constructs": "^10.4.2",
    "dotenv": "^17.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.716.0",
    "@aws-sdk/client-lambda": "^3.840.0",
    "@aws-sdk/client-opensearch": "^3.758.0",
    "@aws-sdk/client-s3": "^3.848.0",
    "@aws-sdk/client-secrets-manager": "^3.716.0",
    "@aws-sdk/util-dynamodb": "^3.767.0",
    "@aws-sdk/util-retry": "^3.370.0",
    "@middy/core": "^6.0.0",
    "@middy/http-cors": "^6.0.0",
    "@middy/http-error-handler": "^6.0.0",
    "@opensearch-project/opensearch": "^3.4.0",
    "@supabase/supabase-js": "^2.49.1",
    "aws-cdk-lib": "2.173.1",
    "aws-lambda": "^1.0.7",
    "pg": "^8.12.0"
  }
}
