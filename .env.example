# Copy this file to .env.local and fill in the values.
# After running `supabase start`, the Supabase values are printed to the terminal.

# ── Supabase (local: http://127.0.0.1:54321) ──────────────────────────────────
# Also used at build time by svelte.config.js to generate the Content Security Policy.
# In Vercel, set this as a project environment variable (not just in .env.local).
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=

# From `supabase start` output — used for server-side operations
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Discord OAuth ──────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# Add redirect URI: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_SECRET=
SUPABASE_AUTH_EXTERNAL_REDIRECT_URL=http://127.0.0.1:54321/auth/v1/callback

# ── Twitch ─────────────────────────────────────────────────────────────────────
# Create an application at https://dev.twitch.tv/console/apps
# Set OAuth redirect URL to your ngrok URL (for local webhook testing)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ngrok auth token for exposing local webhook endpoint to Twitch EventSub
# Get your token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=
